# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
*.egg-info/
.venv/
venv/
env/
.pytest_cache/
.ruff_cache/
.mypy_cache/
.ipynb_checkpoints/

# OS
.DS_Store
Thumbs.db
desktop.ini

# IDE
.vscode/
.idea/
*.swp
*.swo

# Local settings
.claude/settings.local.json

# ──────────────────────────────────────────────────────────────────────────
# Private projects (not part of the open-source template)
# See ADR-0003: only the framework skeleton + projects/README.md is tracked;
# each maintainer's actual projects live under projects/<name>/ and are
# gitignored by default.
# ──────────────────────────────────────────────────────────────────────────
projects/VFormer/

# Project data (never commit raw datasets or experiment outputs)
projects/*/data/
projects/*/results/
projects/*/runs/
projects/*/checkpoints/
projects/*/_cache/

# ──────────────────────────────────────────────────────────────────────────
# Private wiki content — only skeleton (*.template.md + _README.md
# per-folder + .gitkeep) is tracked. Actual wiki pages are the author's
# private knowledge base; open-source consumers fill their own.
# ──────────────────────────────────────────────────────────────────────────
wiki/papers/*.md
wiki/concepts/*.md
wiki/datasets/*.md
wiki/benchmarks/*.md
wiki/syntheses/*.md
!wiki/*/_README.md
# Local user-derived files (cp from *.template.md on first use) — ignored
wiki/index.md
wiki/log.md
# But always track the templates
!wiki/index.template.md
!wiki/log.template.md

# ──────────────────────────────────────────────────────────────────────────
# Private journal + runtime meta (private lab-notebook / operations log).
# Only the skeleton _index.template.md / backlog templates are tracked.
# ──────────────────────────────────────────────────────────────────────────
journal/**
!journal/_index.template.md
!journal/.gitkeep
meta/frictions-backlog.md
meta/improvements-backlog.md
meta/reviews/**
!meta/reviews/.gitkeep
!meta/reviews/_template.md

# ──────────────────────────────────────────────────────────────────────────
# Private writing material (papers/theses are the author's private work
# product). Only the top-level writing/_index.template.md scaffold is tracked.
# ──────────────────────────────────────────────────────────────────────────
writing/*/
writing/_index.md
!writing/_index.template.md

# ──────────────────────────────────────────────────────────────────────────
# Private learning notes (non-task-driven reading). Only the
# learning/_index.template.md scaffold is tracked.
# ──────────────────────────────────────────────────────────────────────────
learning/*
!learning/_index.template.md
!learning/.gitkeep

# ──────────────────────────────────────────────────────────────────────────
# Private schedule / ToDo (author's personal calendar). Only the
# schedule/_index.template.md scaffold is tracked.
# ──────────────────────────────────────────────────────────────────────────
schedule/*
!schedule/_index.template.md
!schedule/.gitkeep

# ──────────────────────────────────────────────────────────────────────────
# Private memory
# - user_*.md: per-user profile (always private).
# - feedback_*.md: cross-project collaboration rules. Tracked only after
#   desensitization. If you fork and add your own, prefix with `private_`
#   or add here to exclude.
# ──────────────────────────────────────────────────────────────────────────
memory/user_*.md
memory/private_*.md

# Large binary artifacts
raw/papers/*.pdf
raw/clippings/*.html
raw/clippings/*.md
*.pkl
*.pth
*.ckpt
*.bin

# But keep manifest template + README stubs
raw/manifest.json
!raw/manifest.template.json
!raw/papers/.gitkeep
!raw/clippings/.gitkeep

# Temp
*.tmp
*.bak
*.bak_*

# Feishu raw dumps (migration-only, not authoritative)
_feishu_raw/

# Session handoff prompts (ephemeral, not part of the template)
_*session-prompt*.md
_next-session-*.md

# Maintainer's private VSCode Front Matter extension config
frontmatter.json
.frontmatter/
